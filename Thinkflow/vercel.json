{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/config/(.*)",
      "status": 403
    },
    {
      "src": "/includes/(.*)",
      "status": 403
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
